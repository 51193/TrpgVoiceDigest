<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="clr-namespace:Markdown.Avalonia;assembly=Markdown.Avalonia"
             xmlns:vm="using:TrpgVoiceDigest.Gui.ViewModels"
             xmlns:views="using:TrpgVoiceDigest.Gui.Views"
             x:Class="TrpgVoiceDigest.Gui.Views.MonitorView"
             x:DataType="vm:MonitorViewModel"
             x:CompileBindings="False">
    <Grid Margin="12" RowDefinitions="Auto,*">
        <!-- Status bar -->
        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,6">
            <Border Width="18" Height="18" CornerRadius="9" Background="{Binding LampBrush}" VerticalAlignment="Center" />
            <TextBlock Text="语音状态" VerticalAlignment="Center" />
            <TextBlock Text="{Binding CurrentCampaign}" Margin="20,0,0,0" FontWeight="Bold" />
            <TextBlock Text="{Binding CurrentSession}" FontWeight="Bold" />
            <TextBlock Text="{Binding StatusMessage}" Margin="20,0,0,0" Foreground="Gray" />
        </StackPanel>

        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}">
            <!-- Tab 0: 转录 -->
            <TabItem Header="转录">
                <ListBox ItemsSource="{Binding TranscriptItems}" Margin="4">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding TimeRange}" Width="120" />
                                <TextBlock Text="{Binding Speaker}" Width="100" Foreground="DodgerBlue" FontWeight="Bold" />
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>

            <!-- Tab 1: 诊断 -->
            <TabItem Header="诊断">
                <StackPanel Margin="8" Spacing="4">
                    <TextBlock Text="音频仪表状态" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding EffectiveInputDevice, StringFormat='输入设备: {0}'}" />
                    <TextBlock Text="{Binding MeterStrategy, StringFormat='发现策略: {0}'}" />
                    <TextBlock Text="{Binding LastRms, StringFormat='最近 RMS: {0:F6}'}" />
                    <TextBlock Text="{Binding OnThreshold, StringFormat='开启阈值: {0:F4}'}" />
                    <TextBlock Text="{Binding OffThreshold, StringFormat='关闭阈值: {0:F4}'}" />
                    <TextBlock Text="{Binding MeterSuccessCount, StringFormat='采样成功: {0}'}" />
                    <TextBlock Text="{Binding MeterErrorCount, StringFormat='采样失败: {0}'}" />
                    <TextBlock Text="{Binding LastMeterAt, StringFormat='最后采样时间: {0}'}" />
                </StackPanel>
            </TabItem>

            <!-- Tab 2: 日志 -->
            <TabItem Header="日志">
                <views:LogsView DataContext="{Binding LogsPage}" />
            </TabItem>

            <!-- Tab 3: 精炼结果 -->
            <TabItem Header="精炼结果">
                <md:MarkdownScrollViewer Markdown="{Binding RefinementMarkdown}" Margin="4" />
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>