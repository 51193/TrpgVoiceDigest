{
  "Audio": {
    "RecorderExecutable": "ffmpeg",
    "InputFormat": "pulse",
    "InputDevice": "default",
    "SampleRate": 16000,
    "Channels": 1,
    "SegmentSeconds": 20,
    "VoiceRmsThreshold": 0.015
  },
  "Whisper": {
    "PythonExecutable": "python/venv/bin/python",
    "ScriptPath": "python/whisper_transcribe.py",
    "Model": "turbo",
    "Language": "zh",
    "InitialPrompt": "以下是普通话的句子。",
    "DiarizationEnabled": true,
    "HuggingFaceTokenEnv": "HF_TOKEN",
    "Device": "cuda",
    "ComputeType": "float16",
    "SkipAlign": true
  },
  "Llm": {
    "BaseUrl": "https://api.openai.com/v1/chat/completions",
    "ApiKeyEnv": "OPENAI_API_KEY",
    "Model": "gpt-4o-mini",
    "RetryCount": 3,
    "TimeoutSeconds": 60,
    "Temperature": 0.05,
    "MaxTokens": 2048,
    "ThinkingEnabled": false,
    "ThinkingTokens": 4096
  },
  "Trigger": {
    "LlmPollingSeconds": 60
  },
  "Storage": {
    "CampaignRoot": "Campaigns"
  },
  "Processing": {
    "TranscribePollingMs": 1000,
    "MeterIntervalMs": 150,
    "MeterWindowMs": 250,
    "DeleteAudioAfterTranscribe": true,
    "SilenceCutMs": 500,
    "MaxSpeechSec": 15.0
  },
  "Prompts": {
    "SystemPromptPath": "prompts/system_digest.md",
    "ConsistencyPromptPath": "prompts/consistency_lexicon.md",
    "ProtocolPromptPath": "prompts/edit_protocol.md",
    "ProcessingRequirementsPath": "prompts/processing_requirements.md",
    "RefinementSystemPromptPath": "prompts/system_refinement.md",
    "RefinementProtocolPath": "prompts/refinement_protocol.md",
    "RefinementRequirementsPath": "prompts/refinement_requirements.md"
  },
  "Ui": {
    "LastCampaignName": "",
    "LastSessionName": ""
  },
  "Refinement": {
    "PollingSeconds": 60,
    "MaxDialogueLines": 25,
    "MaxRefinementSentences": 50,
    "MinContextChars": 1500,
    "MaxContextChars": 10000
  },
  "AudioSegmentation": {
    "HardMaxSpeechSec": 25.0,
    "MinSpeechSec": 0.5,
    "SilenceCutMs": 300,
    "EndOfUtteranceEnabled": false,
    "EndOfUtteranceSensitivity": 0.5
  },
  "CampaignSpeaker": {
    "CampaignSpeakersFilePath": ""
  }
}
