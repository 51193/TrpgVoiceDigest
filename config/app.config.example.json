{
  "Audio": {
    "RecorderExecutable": "tools/ffmpeg/ffmpeg",
    "InputFormat": "pulse",
    "InputDevice": "default",
    "SampleRate": 16000,
    "Channels": 1,
    "VoiceRmsThreshold": 0.015
  },
  "Whisper": {
    "PythonExecutable": "python/venv/bin/python",
    "ScriptPath": "python/whisper_transcribe.py",
    "Model": "turbo",
    "Language": "zh",
    "InitialPrompt": "以下是普通话的句子。",
    "DiarizationEnabled": true,
    "HuggingFaceTokenEnv": "HF_TOKEN",
    "Device": "cuda",
    "ComputeType": "float16",
    "SkipAlign": true
  },
  "Llm": {
    "BaseUrl": "https://api.openai.com/v1/chat/completions",
    "ApiKeyEnv": "OPENAI_API_KEY",
    "Model": "gpt-4o-mini",
    "RetryCount": 3,
    "TimeoutSeconds": 60,
    "Temperature": 0.1,
    "MaxTokens": 2048,
    "ThinkingEnabled": false,
    "ThinkingTokens": 4096
  },
  "Storage": {
    "CampaignRoot": "Campaigns"
  },
  "Prompts": {
    "RefinementSystemPromptPath": "prompts/system_refinement.md",
    "RefinementProtocolPath": "prompts/refinement_protocol.md",
    "RefinementRequirementsPath": "prompts/refinement_requirements.md",
    "ConsistencySystemPromptPath": "prompts/system_consistency.md"
  },
  "Processing": {
    "TranscribePollingMs": 1000,
    "MeterIntervalMs": 150,
    "MeterWindowMs": 250,
    "DeleteAudioAfterTranscribe": true
  },
  "Ui": {
    "LastCampaignName": ""
  },
  "Refinement": {
    "PollingSeconds": 60,
    "MaxDialogueLines": 40,
    "MaxRefinementSentences": 80,
    "MinContextChars": 1500,
    "MaxContextChars": 10000,
    "TotalPromptBudgetChars": 8000,
    "AccumulationMaxChars": 20000,
    "ColdStartDialogueLines": 40
  },
  "AudioSegmentation": {
    "HardMaxSpeechSec": 120.0,
    "MinSpeechSec": 0.3,
    "SilenceCutMs": 400,
    "EndOfUtteranceEnabled": false,
    "EndOfUtteranceSensitivity": 0.5
  },
  "StoryProgress": {
    "PollingSeconds": 90,
    "MaxStoryEntries": 40,
    "MaxContextChars": 8000,
    "AccumulationMaxChars": 20000,
    "ColdStartLines": 30
  }
}
